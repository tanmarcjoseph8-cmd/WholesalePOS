generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id                 String                  @id @default(cuid())
  name               String
  legalName          String?
  phone              String?
  email              String?
  address            String?
  currency           String                  @default("PHP")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  warehouses         Warehouse[]
  users              User[]
  sales              Sale[]
  heldSales          HeldSale[]
  refunds            Refund[]
  settings           Setting[]
  receiptSequences   ReceiptSequence[]
  cashDrawerSessions CashDrawerSession[]
  inventoryImports   InventoryImportBatch[]
  importPresets      InventoryImportPreset[]
  restaurantTables   RestaurantTable[]
  inventoryReservations InventoryReservation[]

  @@index([deletedAt])
}

model Warehouse {
  id          String                 @id @default(cuid())
  storeId     String
  name        String
  code        String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?
  store       Store                  @relation(fields: [storeId], references: [id])
  stocks      InventoryStock[]
  movements   InventoryMovement[]
  stockAlerts StockAlert[]
  imports     InventoryImportBatch[]
  reservations InventoryReservation[]
  saleItems     SaleItem[]
  refundItems   RefundItem[]

  @@unique([storeId, code])
  @@index([storeId, deletedAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model User {
  id                  String                  @id @default(cuid())
  storeId             String?
  roleId              String
  name                String
  email               String                  @unique
  passwordHash        String
  status              String                  @default("ACTIVE")
  isActive            Boolean                 @default(true)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?
  store               Store?                  @relation(fields: [storeId], references: [id])
  role                Role                    @relation(fields: [roleId], references: [id])
  sessions            Session[]
  auditLogs           AuditLog[]              @relation("AuditActor")
  sales               Sale[]                  @relation("CashierSales")
  heldSales           HeldSale[]              @relation("HeldSaleCashier")
  refunds             Refund[]                @relation("RefundCashier")
  inventoryMovements  InventoryMovement[]     @relation("InventoryMovementCreator")
  priceChanges        PriceHistory[]          @relation("PriceChanger")
  receiptPrintLogs    ReceiptPrintLog[]       @relation("ReceiptPrintUser")
  barcodeLabelBatches BarcodeLabelBatch[]     @relation("BarcodeLabelBatchCreator")
  backupRuns          BackupRun[]             @relation("BackupRunCreator")
  uploadedAssets      UploadedAsset[]         @relation("UploadedAssetCreator")
  cashDrawerSessions  CashDrawerSession[]     @relation("CashDrawerCashier")
  createdImports      InventoryImportBatch[]  @relation("InventoryImportCreator")
  rolledBackImports   InventoryImportBatch[]  @relation("InventoryImportRollbackUser")
  importPresets       InventoryImportPreset[] @relation("InventoryImportPresetCreator")
  assignedTables      RestaurantTable[]       @relation("RestaurantTableStaff")
  lockedHeldSales     HeldSale[]              @relation("HeldSaleLockOwner")

  @@index([storeId, deletedAt])
  @@index([roleId])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  email          String?
  phone          String?
  address        String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([deletedAt])
}

model Customer {
  id            String     @id @default(cuid())
  name          String
  email         String?
  phone         String?
  loyaltyPoints Int        @default(0)
  creditLimit   Decimal    @default(0)
  balance       Decimal    @default(0)
  birthday      DateTime?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
  sales         Sale[]
  heldSales     HeldSale[]
  refunds       Refund[]

  @@index([phone])
  @@index([email])
  @@index([deletedAt])
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  @@index([parentId])
  @@index([deletedAt])
}

model Product {
  id                 String               @id @default(cuid())
  categoryId         String?
  supplierId         String?
  sku                String               @unique
  name               String
  variant            String?
  salesChannel       String               @default("RETAIL")
  description        String?
  imageUrl           String?
  brand              String?
  inventoryUnit      String
  sellingUnit        String
  unitRatioToBase    Decimal              @default(1)
  packageSize        Decimal              @default(1)
  costPrice          Decimal
  retailPrice        Decimal
  wholesalePrice     Decimal
  vipPrice           Decimal
  wholesaleThreshold Decimal              @default(0)
  taxRate            Decimal              @default(0)
  minimumStock       Decimal              @default(0)
  maximumStock       Decimal?
  status             String               @default("ACTIVE")
  expiresAt          DateTime?
  batchNumber        String?
  location           String?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?
  category           Category?            @relation(fields: [categoryId], references: [id])
  supplier           Supplier?            @relation(fields: [supplierId], references: [id])
  barcodes           ProductBarcode[]
  stocks             InventoryStock[]
  movements          InventoryMovement[]
  saleItems          SaleItem[]
  heldSaleItems      HeldSaleItem[]
  refundItems        RefundItem[]
  priceHistory       PriceHistory[]
  purchaseOrderItems PurchaseOrderItem[]
  stockAlerts        StockAlert[]
  importRows         InventoryImportRow[]
  reservations       InventoryReservation[]

  @@index([name])
  @@index([name, variant])
  @@index([salesChannel, status])
  @@index([categoryId])
  @@index([supplierId])
  @@index([deletedAt])
}

model ProductBarcode {
  id        String   @id @default(cuid())
  productId String
  value     String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model InventoryStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Decimal   @default(0)
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

model InventoryMovement {
  id              String              @id @default(cuid())
  productId       String
  warehouseId     String
  type            String
  quantity        Decimal
  unitCost        Decimal?
  referenceType   String?
  referenceId     String?
  reason          String?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  product         Product             @relation(fields: [productId], references: [id])
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id])
  createdBy       User?               @relation("InventoryMovementCreator", fields: [createdByUserId], references: [id])
  importRow       InventoryImportRow?
  refundItem      RefundItem?

  @@index([productId, createdAt])
  @@index([warehouseId, createdAt])
  @@index([referenceType, referenceId])
}

model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  priceType   String
  oldPrice    Decimal
  newPrice    Decimal
  changedById String?
  changedAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])
  changedBy   User?    @relation("PriceChanger", fields: [changedById], references: [id])

  @@index([productId, changedAt])
}

model InventoryImportBatch {
  id                 String               @id @default(cuid())
  storeId            String
  warehouseId        String
  createdByUserId    String
  rolledBackByUserId String?
  mode               String
  status             String               @default("PROCESSING")
  sourceName         String
  sourceSizeBytes    Int?
  fingerprint        String
  rowCount           Int
  validCount         Int                  @default(0)
  warningCount       Int                  @default(0)
  invalidCount       Int                  @default(0)
  createdCount       Int                  @default(0)
  updatedCount       Int                  @default(0)
  skippedCount       Int                  @default(0)
  failedCount        Int                  @default(0)
  stockDelta         Decimal              @default(0)
  durationMs         Int?
  summary            Json?
  createdAt          DateTime             @default(now())
  completedAt        DateTime?
  rolledBackAt       DateTime?
  store              Store                @relation(fields: [storeId], references: [id])
  warehouse          Warehouse            @relation(fields: [warehouseId], references: [id])
  createdBy          User                 @relation("InventoryImportCreator", fields: [createdByUserId], references: [id])
  rolledBackBy       User?                @relation("InventoryImportRollbackUser", fields: [rolledBackByUserId], references: [id])
  rows               InventoryImportRow[]

  @@index([storeId, createdAt])
  @@index([storeId, fingerprint])
  @@index([status, createdAt])
  @@index([warehouseId, createdAt])
}

model InventoryImportRow {
  id                  String               @id @default(cuid())
  batchId             String
  rowNumber           Int
  productId           String?
  inventoryMovementId String?              @unique
  action              String
  status              String
  matchMethod         String?
  previousProduct     Json?
  newProduct          Json?
  previousStock       Decimal?
  newStock            Decimal?
  quantityChanged     Decimal?
  warnings            Json?
  errors              Json?
  createdAt           DateTime             @default(now())
  batch               InventoryImportBatch @relation(fields: [batchId], references: [id])
  product             Product?             @relation(fields: [productId], references: [id])
  inventoryMovement   InventoryMovement?   @relation(fields: [inventoryMovementId], references: [id])

  @@unique([batchId, rowNumber])
  @@index([productId, createdAt])
  @@index([status, createdAt])
}

model InventoryImportPreset {
  id              String    @id @default(cuid())
  storeId         String
  createdByUserId String
  name            String
  mapping         Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  store           Store     @relation(fields: [storeId], references: [id])
  createdBy       User      @relation("InventoryImportPresetCreator", fields: [createdByUserId], references: [id])

  @@index([storeId, deletedAt])
  @@index([createdByUserId, createdAt])
}

model Sale {
  id            String            @id @default(cuid())
  storeId       String
  cashierId     String
  customerId    String?
  heldSaleId    String?           @unique
  receiptNumber String            @unique
  orderNumber   String?           @unique
  orderType     String            @default("RETAIL")
  customOrderType String?
  status        String            @default("COMPLETED")
  subtotal      Decimal
  discountTotal Decimal           @default(0)
  taxTotal      Decimal           @default(0)
  grandTotal    Decimal
  paidTotal     Decimal
  changeTotal   Decimal           @default(0)
  serviceCharge Decimal           @default(0)
  tip           Decimal           @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  store         Store             @relation(fields: [storeId], references: [id])
  cashier       User              @relation("CashierSales", fields: [cashierId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  heldSale      HeldSale?         @relation("HeldSaleCompletion", fields: [heldSaleId], references: [id])
  items         SaleItem[]
  payments      SalePayment[]
  refunds       Refund[]          @relation("OriginalSaleRefunds")
  printLogs     ReceiptPrintLog[]

  @@index([storeId, createdAt])
  @@index([orderType, createdAt])
  @@index([cashierId, createdAt])
  @@index([customerId])
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  productId    String
  warehouseId  String?
  quantity     Decimal
  soldQuantity Decimal @default(1)
  soldUnit     String  @default("PIECE")
  baseQuantity Decimal @default(1)
  unitPrice    Decimal
  discount     Decimal @default(0)
  taxAmount    Decimal @default(0)
  lineTotal    Decimal
  sale         Sale    @relation(fields: [saleId], references: [id])
  product      Product @relation(fields: [productId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  refundItems  RefundItem[]

  @@index([saleId])
  @@index([productId])
  @@index([warehouseId])
}

model SalePayment {
  id        String   @id @default(cuid())
  saleId    String
  method    String
  amount    Decimal
  reference String?
  createdAt DateTime @default(now())
  sale      Sale     @relation(fields: [saleId], references: [id])

  @@index([saleId])
}

model Setting {
  id        String   @id @default(cuid())
  storeId   String?
  scope     String   @default("STORE")
  key       String
  value     Json
  valueType String   @default("json")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store?   @relation(fields: [storeId], references: [id])

  @@unique([storeId, key])
  @@index([scope])
}

model ReceiptSequence {
  id         String   @id @default(cuid())
  storeId    String
  prefix     String   @default("POS")
  nextNumber Int      @default(1)
  padding    Int      @default(6)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  store      Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, prefix])
}

model ReceiptPrintLog {
  id           String   @id @default(cuid())
  saleId       String?
  refundId     String?
  printedById  String?
  printerName  String?
  printerType  String   @default("WINDOWS")
  paperWidth   String?
  status       String
  errorMessage String?
  printedAt    DateTime @default(now())
  sale         Sale?    @relation(fields: [saleId], references: [id])
  refund       Refund?  @relation(fields: [refundId], references: [id])
  printedBy    User?    @relation("ReceiptPrintUser", fields: [printedById], references: [id])

  @@index([saleId, printedAt])
  @@index([refundId, printedAt])
  @@index([status, printedAt])
}

model HeldSale {
  id             String            @id @default(cuid())
  storeId        String
  cashierId      String
  customerId     String?
  primaryTableId String?
  lockedByUserId String?
  mergedIntoOrderId String?
  splitFromOrderId String?
  orderNumber    String?           @unique
  orderType      String            @default("WALK_IN")
  customOrderType String?
  status         String            @default("DRAFT")
  label          String?
  customerName   String?
  customerPhone  String?
  queueNumber    String?
  guestCount     Int               @default(1)
  note           String?
  subtotal       Decimal           @default(0)
  discountTotal  Decimal           @default(0)
  taxTotal       Decimal           @default(0)
  grandTotal     Decimal           @default(0)
  serviceCharge  Decimal           @default(0)
  tip            Decimal           @default(0)
  version        Int               @default(1)
  lockExpiresAt  DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  reopenedAt     DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  expiresAt      DateTime?
  deletedAt      DateTime?
  store          Store             @relation(fields: [storeId], references: [id])
  cashier        User              @relation("HeldSaleCashier", fields: [cashierId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])
  primaryTable   RestaurantTable?  @relation("PrimaryRestaurantTable", fields: [primaryTableId], references: [id])
  assignedTables RestaurantTable[] @relation("ActiveOrderTables")
  lockedBy       User?             @relation("HeldSaleLockOwner", fields: [lockedByUserId], references: [id])
  completedSale  Sale?             @relation("HeldSaleCompletion")
  mergedInto     HeldSale?         @relation("HeldSaleMerges", fields: [mergedIntoOrderId], references: [id])
  mergedOrders   HeldSale[]        @relation("HeldSaleMerges")
  splitFrom      HeldSale?         @relation("HeldSaleSplits", fields: [splitFromOrderId], references: [id])
  splitOrders    HeldSale[]        @relation("HeldSaleSplits")
  items          HeldSaleItem[]
  reservations   InventoryReservation[]

  @@index([storeId, updatedAt])
  @@index([storeId, status, updatedAt])
  @@index([cashierId, updatedAt])
  @@index([primaryTableId])
  @@index([lockedByUserId, lockExpiresAt])
  @@index([mergedIntoOrderId])
  @@index([splitFromOrderId])
  @@index([deletedAt])
}

model HeldSaleItem {
  id           String   @id @default(cuid())
  heldSaleId   String
  productId    String
  warehouseId  String?
  quantity     Decimal
  soldUnit     String   @default("PIECE")
  baseQuantity Decimal  @default(1)
  unitPrice    Decimal
  discount     Decimal  @default(0)
  taxAmount    Decimal  @default(0)
  lineTotal    Decimal
  note         String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  heldSale     HeldSale @relation(fields: [heldSaleId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
  reservations InventoryReservation[]

  @@index([heldSaleId])
  @@index([productId])
  @@index([warehouseId])
  @@index([heldSaleId, deletedAt])
}

model InventoryReservation {
  id             String       @id @default(cuid())
  storeId        String
  heldSaleId     String
  heldSaleItemId String?
  productId      String
  warehouseId    String
  quantity       Decimal
  status         String       @default("ACTIVE")
  reason         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  releasedAt     DateTime?
  consumedAt     DateTime?
  store          Store        @relation(fields: [storeId], references: [id])
  heldSale       HeldSale     @relation(fields: [heldSaleId], references: [id])
  heldSaleItem   HeldSaleItem? @relation(fields: [heldSaleItemId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id])

  @@index([heldSaleId, status])
  @@index([heldSaleItemId])
  @@index([productId, warehouseId, status])
  @@index([storeId, status, createdAt])
}

model RestaurantTable {
  id              String     @id @default(cuid())
  storeId         String
  assignedStaffId String?
  activeOrderId   String?
  number          String
  section         String     @default("Main")
  capacity        Int        @default(2)
  status          String     @default("AVAILABLE")
  guestCount      Int        @default(0)
  occupiedAt      DateTime?
  notes           String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  store           Store      @relation(fields: [storeId], references: [id])
  assignedStaff   User?      @relation("RestaurantTableStaff", fields: [assignedStaffId], references: [id])
  activeOrder     HeldSale?  @relation("ActiveOrderTables", fields: [activeOrderId], references: [id])
  primaryOrders   HeldSale[] @relation("PrimaryRestaurantTable")

  @@unique([storeId, number])
  @@index([storeId, section, status])
  @@index([activeOrderId])
  @@index([assignedStaffId])
  @@index([deletedAt])
}

model Refund {
  id             String            @id @default(cuid())
  storeId        String
  cashierId      String
  customerId     String?
  originalSaleId String?
  requestKey     String?           @unique
  kind           String            @default("REFUND")
  receiptNumber  String            @unique
  reason         String
  subtotal       Decimal
  taxTotal       Decimal           @default(0)
  grandTotal     Decimal
  status         String            @default("COMPLETED")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  store          Store             @relation(fields: [storeId], references: [id])
  cashier        User              @relation("RefundCashier", fields: [cashierId], references: [id])
  customer       Customer?         @relation(fields: [customerId], references: [id])
  originalSale   Sale?             @relation("OriginalSaleRefunds", fields: [originalSaleId], references: [id])
  items          RefundItem[]
  payments       RefundPayment[]
  printLogs      ReceiptPrintLog[]

  @@index([storeId, createdAt])
  @@index([cashierId, createdAt])
  @@index([originalSaleId])
}

model RefundItem {
  id                  String             @id @default(cuid())
  refundId            String
  saleItemId          String?
  productId           String
  warehouseId         String?
  inventoryMovementId String?            @unique
  quantity            Decimal
  soldQuantity        Decimal            @default(1)
  baseQuantity        Decimal            @default(1)
  unitPrice           Decimal
  taxAmount           Decimal            @default(0)
  lineTotal           Decimal
  refund              Refund             @relation(fields: [refundId], references: [id])
  saleItem            SaleItem?           @relation(fields: [saleItemId], references: [id])
  product             Product            @relation(fields: [productId], references: [id])
  warehouse           Warehouse?          @relation(fields: [warehouseId], references: [id])
  inventoryMovement   InventoryMovement?  @relation(fields: [inventoryMovementId], references: [id])

  @@index([refundId])
  @@index([productId])
  @@index([saleItemId])
  @@index([warehouseId])
}

model RefundPayment {
  id        String   @id @default(cuid())
  refundId  String
  method    String
  amount    Decimal
  reference String?
  createdAt DateTime @default(now())
  refund    Refund   @relation(fields: [refundId], references: [id])

  @@index([refundId])
}

model BarcodeLabelBatch {
  id              String    @id @default(cuid())
  createdByUserId String?
  labelType       String
  paperSize       String?
  itemCount       Int
  status          String    @default("CREATED")
  metadata        Json?
  createdAt       DateTime  @default(now())
  printedAt       DateTime?
  createdBy       User?     @relation("BarcodeLabelBatchCreator", fields: [createdByUserId], references: [id])

  @@index([createdByUserId, createdAt])
  @@index([status, createdAt])
}

model BackupRun {
  id              String    @id @default(cuid())
  createdByUserId String?
  type            String
  status          String
  filePath        String?
  fileSizeBytes   BigInt?
  errorMessage    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdBy       User?     @relation("BackupRunCreator", fields: [createdByUserId], references: [id])

  @@index([type, startedAt])
  @@index([status, startedAt])
}

model UploadedAsset {
  id               String    @id @default(cuid())
  uploadedByUserId String?
  purpose          String
  originalName     String
  storedName       String
  mimeType         String
  sizeBytes        BigInt
  relativePath     String
  checksum         String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  uploadedBy       User?     @relation("UploadedAssetCreator", fields: [uploadedByUserId], references: [id])

  @@index([purpose, createdAt])
  @@index([deletedAt])
}

model CashDrawerSession {
  id           String    @id @default(cuid())
  storeId      String
  cashierId    String
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  openingCash  Decimal   @default(0)
  closingCash  Decimal?
  expectedCash Decimal?
  variance     Decimal?
  status       String    @default("OPEN")
  notes        String?
  store        Store     @relation(fields: [storeId], references: [id])
  cashier      User      @relation("CashDrawerCashier", fields: [cashierId], references: [id])

  @@index([storeId, openedAt])
  @@index([cashierId, openedAt])
  @@index([status])
}

model StockAlert {
  id          String     @id @default(cuid())
  productId   String
  warehouseId String?
  type        String
  status      String     @default("OPEN")
  threshold   Decimal?
  quantity    Decimal
  createdAt   DateTime   @default(now())
  resolvedAt  DateTime?
  product     Product    @relation(fields: [productId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@index([productId, status])
  @@index([warehouseId, status])
  @@index([type, status])
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  supplierId String
  status     String              @default("DRAFT")
  orderDate  DateTime            @default(now())
  expectedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  deletedAt  DateTime?
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]

  @@index([supplierId, status])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  orderedQuantity  Decimal
  receivedQuantity Decimal       @default(0)
  unitCost         Decimal
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}
