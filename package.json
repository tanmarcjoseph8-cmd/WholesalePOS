{
  "name": "wholesalepos-enterprise",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise wholesale and retail POS platform.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @wholesalepos/backend --filter @wholesalepos/frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @wholesalepos/backend db:generate",
    "db:migrate": "pnpm --filter @wholesalepos/backend db:migrate",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2",
    "typescript": "^5.7.2"
  }
}
