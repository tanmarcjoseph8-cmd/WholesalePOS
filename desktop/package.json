{
  "name": "@wholesalepos/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Offline Windows desktop shell for WholesalePOS.",
  "author": "WholesalePOS",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "pnpm --filter @wholesalepos/backend build && pnpm --filter @wholesalepos/frontend build && tsc -p tsconfig.json",
    "dev": "pnpm build && electron .",
    "lint": "eslint .",
    "installer:win": "pnpm build && node ../scripts/prepare-desktop-assets.mjs && electron-builder --win nsis --x64",
    "package:win": "pnpm build && node ../scripts/prepare-desktop-assets.mjs && electron-builder --win zip --x64",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "electron-updater": "^6.3.9",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.1.0",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.wholesalepos.desktop",
    "productName": "WholesalePOS",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "app-assets/**",
      "node_modules/.prisma/**",
      "node_modules/@prisma/client/.prisma/**",
      "node_modules/prisma/query-engine*.exe",
      "node_modules/@prisma/engines/**",
      "package.json"
    ],
    "win": {
      "target": "zip"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
